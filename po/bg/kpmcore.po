msgstr "Брой цикли на зареждане/разтоварване"

#: core/smartattribute.cpp:137
#, kde-format
msgctxt "SMART attr description"
msgid "Count of load/unload cycles into head landing zone position."
msgstr "Брой цикли на зареждане/разтоварване на главите в зоната за паркиране."

