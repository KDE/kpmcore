msgctxt "@info:status"
msgid "An error occurred while running lvdisplay."
msgstr "Възникна грешка при изпълнението на lvdisplay."

#: core/operationstack.cpp:101
#, kde-kuit-format
msgctxt "@info:status"
msgid ""
"Deleting a partition just created: Undoing the operation to create the "
"partition."
msgstr ""
"Изтриване на току-що създаден дял: отмяна на операцията за създаване на дял."

#: core/operationstack.cpp:119
#, kde-kuit-format
msgctxt "@info:status"
msgid ""
"Resizing a partition just created: Updating start and end in existing "
"operation."
msgstr ""
"Преоразмеряване на току-що създаден дял: актуализиране на началото и края в "
"съществуващата операция."

#: core/operationstack.cpp:139
#, kde-kuit-format
msgctxt "@info:status"
msgid "Copying a new partition: Creating a new partition instead."
msgstr "Копиране на нов дял: създаване на нов дял вместо това."

#: core/operationstack.cpp:156
#, kde-kuit-format
msgctxt "@info:status"
msgid "Changing label for a new partition: No new operation required."
msgstr "Промяна на етикета на нов дял: не се изисква нова операция."

#: core/operationstack.cpp:169
#, kde-kuit-format
msgctxt "@info:status"
msgid "Changing file system for a new partition: No new operation required."
msgstr "Промяна на файловата система за нов дял: не се изисква нова операция."

#: core/operationstack.cpp:186
#, kde-kuit-format
msgctxt "@info:status"
msgid ""
"Checking file systems is automatically done when creating them: No new "
"operation required."
msgstr ""
"Проверката на файловите системи се извършва автоматично при създаването им: "
"не се изисква нова операция."

#: core/operationstack.cpp:233
#, kde-kuit-format
msgctxt "@info:status"
msgid "Deleting a partition just copied: Removing the copy."
msgstr "Изтриване на току-що копиран дял: премахване на копието."

#: core/operationstack.cpp:238
#, kde-kuit-format
msgctxt "@info:status"
msgid ""
"Deleting a partition just copied over an existing partition: Removing the "
"copy and deleting the existing partition."
msgstr ""
"Изтриване на дял, току-що копиран върху съществуващ: премахване на копието и "
"изтриване на съществуващия дял."

#: core/operationstack.cpp:251
#, kde-kuit-format
msgctxt "@info:status"
msgid ""
"Copying a partition that is itself a copy: Copying the original source "
"partition instead."
msgstr ""
"Копиране на дял, който самият е копие: копиране на оригиналния изходен дял "
"вместо това."

#: core/operationstack.cpp:280
#, kde-kuit-format
msgctxt "@info:status"
msgid "Deleting a partition just restored: Removing the restore operation."
msgstr ""
"Изтриване на току-що възстановен дял: премахване на операцията за "
"възстановяване."

#: core/operationstack.cpp:285
#, kde-kuit-format
msgctxt "@info:status"
msgid ""
"Deleting a partition just restored to an existing partition: Removing the "
"restore operation and deleting the existing partition."
msgstr ""
"Изтриване на дял, току-що възстановен върху съществуващ: премахване на "
"операцията за възстановяване и изтриване на съществуващия дял."

#: core/operationstack.cpp:318
#, kde-kuit-format
msgctxt "@info:status"
msgid "Changing flags again for the same partition: Removing old operation."
msgstr ""
"Повторна промяна на флаговете за същия дял: премахване на старата операция."

#: core/operationstack.cpp:349
#, kde-kuit-format
msgctxt "@info:status"
msgid "Changing label again for the same partition: Removing old operation."
msgstr ""
"Повторна промяна на етикета за същия дял: премахване на старата операция."

#: core/operationstack.cpp:375
#, kde-kuit-format
msgctxt "@info:status"
msgid "Creating new partition table, discarding previous operation on device."
msgstr ""
"Създаване на нова таблица с дялове, отхвърляне на предишната операция на "
"устройството."

#: core/operationstack.cpp:395
#, kde-kuit-format
msgctxt "@info:status"
msgid "Resizing Volume Group, nothing to do."
msgstr ""
"Преоразмеряване на групата от томове (Volume Group), няма нищо за правене."

#: core/operationstack.cpp:440
#, kde-kuit-format
msgctxt "@info:status"
msgid "Add operation: %1"
msgstr "Добавяне на операция: %1"

