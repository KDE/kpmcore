#: core/smartattribute.cpp:154
#, kde-format
msgctxt "SMART attr description"
msgid "Vibration During Write"
msgstr "Вибрация по време на запис"

#: core/smartattribute.cpp:155
#, kde-format
msgctxt "SMART attr name"
