msgstr "Честота на грешките от външни сътресения"

#: core/smartattribute.cpp:135
#, kde-format
msgctxt "SMART attr description"
msgid "Count of errors resulting from externally-induced shock and vibration."
msgstr "Брой грешки, причинени от външни удари и вибрации."

#: core/smartattribute.cpp:136
#, kde-format
msgctxt "SMART attr name"
msgid "Power Off Retract Count"
msgstr "Брой прибирания на главите при изключване"

#: core/smartattribute.cpp:136
#, kde-format
msgctxt "SMART attr description"
msgid "Count of power-off or emergency retract cycles"
msgstr ""
