msgstr "Общо записани LBA сектори"

#: core/smartattribute.cpp:173
#, kde-format
msgctxt "SMART attr name"
msgid "Total LBAs Read"
msgstr "Общо прочетени LBA сектори"

#: core/smartattribute.cpp:173
#, kde-format
msgctxt "SMART attr description"
msgid "Total LBAs Read"
msgstr "Общо прочетени LBA сектори"

#: core/smartattribute.cpp:174
#, kde-format
msgctxt "SMART attr name"
